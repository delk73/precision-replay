#!/usr/bin/env bash
set -eu

msg_file="${1:?commit message file required}"

missing=0

require_pattern() {
    label="$1"
    pattern="$2"

    if ! grep -Eq "$pattern" "$msg_file"; then
        echo "ERROR: Commit message must include $label" >&2
        missing=1
    fi
}

require_pattern "Objective:" '^Objective:'
require_pattern "Scope:" '^Scope:'
require_pattern "Baseline SHA:" '^Baseline SHA:'
require_pattern "Cargo test result:" '^Cargo test result:'
require_pattern "Kani verification result:" '^Kani verification result:'
require_pattern "Verifier review note:" '^Verifier review note:'
require_pattern "Acceptance disposition:" '^Acceptance disposition:'

field_value() {
    label="$1"

    awk -v label="$label" '
        index($0, label) == 1 {
            value = substr($0, length(label) + 1)
            sub(/^[[:space:]]*/, "", value)
            if (value != "") {
                print value
                exit
            }
            found = 1
            next
        }
        found && NF {
            print
            exit
        }
    ' "$msg_file"
}

baseline_sha="$(field_value "Baseline SHA:")"
acceptance_disposition="$(field_value "Acceptance disposition:")"

if ! printf '%s\n' "$baseline_sha" | grep -Eq '^[0-9a-fA-F]{40}$'; then
    echo "ERROR: Baseline SHA must be a 40-character git SHA." >&2
    missing=1
fi

if ! printf '%s\n' "$acceptance_disposition" | grep -Eq '^(Accepted for merge|Accepted|Blocked|Rejected)$'; then
    echo "ERROR: Acceptance disposition must be one of: Accepted for merge, Accepted, Blocked, Rejected." >&2
    missing=1
fi

if [ "$missing" -eq 1 ]; then
    cat >&2 <<'EOF'

Commit message schema violation.

Required shape:

<summary>

Objective:
<what this change does>

Scope:
- <files/surfaces changed>

Baseline SHA:
<40-character SHA>

Cargo test result:
- <command>: <result>

Kani verification result:
- <command>: <result>
# or:
Not applicable; <reason>

Verifier review note:
<review note>

Acceptance disposition:
Accepted for merge
EOF
    exit 1
fi

exit 0
