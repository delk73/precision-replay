#!/usr/bin/env bash
set -eu

msg_file="${1:?commit message file required}"

missing=0

subject="$(grep -vE '^[[:space:]]*(#|$)' "$msg_file" | head -n 1 || true)"
if [ -z "$subject" ]; then
    echo "ERROR: Commit message must include a non-empty subject." >&2
    missing=1
fi

require_field() {
    label="$1"

    if ! grep -Eq "^${label}[[:space:]]*$|^${label}[[:space:]]+" "$msg_file"; then
        echo "ERROR: Commit message must include $label" >&2
        missing=1
    fi
}

require_field "Baseline SHA:"
require_field "Cargo test result:"
require_field "Kani verification result:"
require_field "Acceptance disposition:"

field_value() {
    label="$1"

    awk -v label="$label" '
        index($0, label) == 1 {
            value = substr($0, length(label) + 1)
            sub(/^[[:space:]]*/, "", value)
            if (value != "") {
                print value
                exit
            }
            found = 1
            next
        }
        found && /^(Objective|Scope|Baseline SHA|Cargo test result|Kani verification result|Verifier review note|Acceptance disposition):/ {
            exit
        }
        found && NF {
            print
            exit
        }
    ' "$msg_file"
}

require_value() {
    label="$1"
    value="$(field_value "$label")"

    if [ -z "$value" ]; then
        echo "ERROR: Commit message must include a value for $label" >&2
        missing=1
    fi
}

require_value "Baseline SHA:"
require_value "Cargo test result:"
require_value "Kani verification result:"
require_value "Acceptance disposition:"

baseline_sha="$(field_value "Baseline SHA:")"
acceptance_disposition="$(field_value "Acceptance disposition:")"

if [ -n "$baseline_sha" ] && printf '%s\n' "$baseline_sha" | grep -Eq '^[0-9a-fA-F]+$' \
    && ! printf '%s\n' "$baseline_sha" | grep -Eq '^[0-9a-f]{40}$'; then
    echo "ERROR: Baseline SHA values must use a 40-character lowercase git SHA." >&2
    missing=1
fi

if ! printf '%s\n' "$acceptance_disposition" | grep -Eq '^(Accepted for merge|Accepted|Blocked|Rejected)$'; then
    echo "ERROR: Acceptance disposition must be one of: Accepted for merge, Accepted, Blocked, Rejected." >&2
    missing=1
fi

if [ "$missing" -eq 1 ]; then
    cat >&2 <<'EOF'

Commit message schema violation.

Required fields:

<summary>

Baseline SHA:
<40-character lowercase SHA, or PR-record reference>

Cargo test result:
<normal prose is OK>

Kani verification result:
<normal prose or justified non-applicability is OK>

Acceptance disposition:
Accepted for merge | Accepted | Blocked | Rejected
EOF
    exit 1
fi

exit 0
